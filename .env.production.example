# Production build-time variables for `npm run deploy:hosting`
# Copy to `.env.production` (gitignored) or set in CI before `vite build`.
# Gemini AI calls in production go through Cloud Functions + Secret Manager — do NOT set VITE_GEMINI_API_KEY here.

# Recommended: reCAPTCHA v2 for login/sign-up bot protection
# https://www.google.com/recaptcha/admin — add novaspace.work and www.novaspace.work
# VITE_RECAPTCHA_SITE_KEY=your-recaptcha-v2-site-key

# Optional: Firebase App Check (register reCAPTCHA v3 in Firebase Console first)
# VITE_APPCHECK_SITE_KEY=your-recaptcha-v3-site-key

# Optional: project-specific Web Push VAPID public key
# Firebase Console → Project Settings → Cloud Messaging → Web configuration → Key pair
# VITE_FIREBASE_VAPID_KEY=your-web-push-vapid-key-here

# Crashlytics / Performance Monitoring (enabled automatically in production builds)
# VITE_ENABLE_CRASHLYTICS=false

# Cloud Functions secrets (set via Secret Manager, not here):
#   npm run setup:secrets -- GEMINI_API_KEY "<key>"
#   npm run setup:secrets -- OWNER_PASSCODE "<strong-passcode>"
#   npm run setup:secrets -- RECAPTCHA_SECRET_KEY "<secret>"
#   npm run functions:deploy
