{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm.cmd --prefix functions run build"
      ]
    }
  ],
  "firestore": [
    {
      "database": "ai-studio-novaspacecoworki-863fc540-4213-48e8-8f94-f914c1f6fe77",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "auth": {
    "authorizedDomains": [
      "localhost",
      "127.0.0.1",
      "refined-legend-420223.firebaseapp.com",
      "refined-legend-420223.web.app"
    ],
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "NovaSpace Coworking",
        "supportEmail": "support@novaspace.ai"
      }
    }
  },
  "extensions": {
    "firestore-send-email": "firebase/firestore-send-email@0.2.9"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}
