{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm.cmd --prefix functions run build"
      ]
    }
  ],
  "firestore": [
    {
      "database": "ai-studio-novaspacecoworki-863fc540-4213-48e8-8f94-f914c1f6fe77",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/firebase-messaging-sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "auth": {
    "authorizedDomains": [
      "localhost",
      "127.0.0.1",
      "refined-legend-420223.firebaseapp.com",
      "refined-legend-420223.web.app",
      "novaspace.work",
      "www.novaspace.work"
    ],
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "Nova Space",
        "supportEmail": "support@novaspace.work",
        "privacyPolicyUrl": "https://novaspace.work/privacy",
        "termsOfServiceUrl": "https://novaspace.work/terms"
      }
    }
  },
  "remoteconfig": {
    "template": "remote-config.template.json"
  },
  "extensions": {
    "firestore-send-email": "firebase/firestore-send-email@0.2.9"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}
