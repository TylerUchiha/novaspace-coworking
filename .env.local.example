# Local dev only — production Gemini calls go through Cloud Functions + Secret Manager.
# VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Firebase Emulator Suite (Auth, Firestore, Functions — no production data)
# VITE_USE_FIREBASE_EMULATORS=true

# Optional: enable Firebase App Check (register reCAPTCHA v3 in Firebase Console first)
# VITE_APPCHECK_SITE_KEY=your-recaptcha-v3-site-key

# reCAPTCHA v2 for login/sign-up bot protection (https://www.google.com/recaptcha/admin)
# VITE_RECAPTCHA_SITE_KEY=your-recaptcha-v2-site-key

# Crashlytics EAP (optional — peer-deps conflict with firebase@12; install manually if needed):
#   npm install @firebase/crashlytics@eap-crashlytics --legacy-peer-deps
# VITE_ENABLE_MONITORING=true
# VITE_ENABLE_CRASHLYTICS=false

# Firebase Cloud Messaging — Web Push (optional project-specific key)
# Firebase Console → Project Settings → Cloud Messaging → Web configuration → Key pair
# If unset, the app uses Firebase's default Web Push key (works for most projects).
# VITE_FIREBASE_VAPID_KEY=your-web-push-vapid-key-here

# Phone auth test mode for localhost SMS (development only)
# VITE_PHONE_AUTH_TEST_MODE=true
#
# Firebase Phone Auth + Egypt SMS region (production):
#   npm run configure:phone-auth
# Test SMS on https://novaspace.work (not localhost).
