# Cloud Functions secrets — do NOT commit real values.
# Set via Firebase CLI (grants Cloud Functions runtime access automatically):
#   firebase functions:secrets:set GEMINI_API_KEY
#   firebase functions:secrets:set OWNER_PASSCODE
#   firebase functions:secrets:set RECAPTCHA_SECRET_KEY
#   firebase functions:secrets:set WHATSAPP_TOKEN
#   firebase functions:secrets:set WHATSAPP_PHONE_NUMBER_ID
#
# Or with gcloud (project number 1098807214267):
#   echo -n "your-key" | gcloud secrets create GEMINI_API_KEY --project=refined-legend-420223 --data-file=-
#   echo -n "your-passcode" | gcloud secrets create OWNER_PASSCODE --project=refined-legend-420223 --data-file=-
#
# Optional Titan SMTP password for the Firestore Send Email extension secret:
#   $env:TITAN_SMTP_PASSWORD = 'your-support@novaspace.work-password'
#   node ../scripts/set-titan-smtp-secret.mjs
#
# FIRESTORE_BACKUP_BUCKET=refined-legend-420223-firestore-backups
#
# Optional manual export trigger key for triggerFirestoreExport HTTP endpoint:
# FIRESTORE_EXPORT_TRIGGER_KEY=change-me
#
# WhatsApp OTP template (params — safe defaults; must match Meta-approved template)
# WHATSAPP_TEMPLATE_NAME=novaspace_phone_otp
# WHATSAPP_TEMPLATE_LANG=en_US
